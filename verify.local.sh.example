#   npm run typecheck
#   QUALITY_CHECKS_RAN=1
#
#   echo "[ralph-verify] running lint"
#   npm run lint
#   QUALITY_CHECKS_RAN=1
#
#   TEST_SCRIPT="test"
#   TEST_SCRIPT_SUPPORTS_TARGETING=1
# }
