#!/usr/bin/env bash
# Optional repo-local Ralph verification adapter.
#
# Copy this file to scripts/ralph/verify.local.sh and customize it for your repo.
# Ralph will source it before running verification.
#
# Available hooks:
#   ralph_verify_adapter_name
#   ralph_verify_run_base_checks
#   ralph_verify_discover_targeted_tests
#   ralph_verify_run_targeted_tests
#   ralph_verify_run_full_suite
#
# Helpful core helpers exposed by ralph-verify.sh:
#   collect_changed_files
#   list_repo_test_files
#
# Example Node/TypeScript adapter:
#
# ralph_verify_adapter_name() {
#   printf 'node\n'
# }
#
