{
  "harnesses": {
    "codex": {
      "name": "OpenAI Codex",
      "provider": "openai",
      "access_method": "api",
      "supports_model_selection": true,
      "supports_agent_selection": true,
      "default_agent": "default",
      "default_model": "gpt-5.4-mini",
      "available_models": [
        "gpt-5.5",
        "gpt-5.4-mini",
        "gpt-5.4",
        "gpt-5",
        "gpt-5-mini",
        "gpt-4.1"
      ],
      "model_parameter": "--model",
      "agent_parameter": "--agent"
    },
    "piagent": {
      "name": "PI Agent",
      "provider": "pi",
      "access_method": "api",
      "supports_model_selection": true,
      "supports_agent_selection": false,
      "default_agent": "default",
      "default_model": "gpt-5.4",
      "available_models": [
        "openrouter/openai/gpt-5.5",
        "openrouter/openai/gpt-5.4-mini",
        "gpt-5",
        "gpt-5.4",
        "gpt-4.1"
      ],
      "model_parameter": "--model",
      "agent_parameter": null
    }
  }
}
